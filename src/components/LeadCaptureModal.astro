---
// Astro 6 Pure Component using native <dialog> element
// Replaces React modal libraries with zero runtime cost
// Performance: ~0KB JS overhead, instant rendering, accessible by default

interface Props {
  title: string;
  description?: string;
  isOpen?: boolean;
}

const { title, description = "", isOpen = false } = Astro.props;
---

<!-- Native HTML5 dialog element - no library needed -->
<dialog
  id="lead-modal"
  class="backdrop:bg-black/50 rounded-lg shadow-2xl max-w-md w-full mx-auto border border-gray-200"
  open={isOpen}
>
  <form method="dialog" class="p-6">
    <!-- Header -->
    <div class="flex items-start justify-between mb-4">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">{title}</h2>
        {description && <p class="text-gray-600 text-sm mt-1">{description}</p>}
      </div>
      <button
        type="button"
        id="close-modal"
        class="text-gray-500 hover:text-gray-700 transition"
        aria-label="Close modal"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>

    <!-- Content Slot -->
    <div class="mb-6" id="modal-content">
      <slot />
    </div>

    <!-- Footer Actions -->
    <div class="flex gap-3">
      <button
        type="button"
        id="modal-cancel"
        class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition font-medium"
      >
        Cancel
      </button>
      <button
        type="submit"
        id="modal-submit"
        class="flex-1 px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition font-medium"
      >
        Submit
      </button>
    </div>
  </form>
</dialog>

<!-- Trigger Button (optional) -->
<button
  type="button"
  id="open-modal-btn"
  class="px-4 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition"
>
  <slot name="trigger">Open Modal</slot>
</button>

<script>
  // Native dialog API - no library overhead
  class ModalController {
    constructor() {
      this.dialog = document.getElementById('lead-modal');
      this.openBtn = document.getElementById('open-modal-btn');
      this.closeBtn = document.getElementById('close-modal');
      this.cancelBtn = document.getElementById('modal-cancel');
      this.submitBtn = document.getElementById('modal-submit');

      this.init();
    }

    init() {
      // Open modal
      if (this.openBtn) {
        this.openBtn.addEventListener('click', () => this.openModal());
      }

      // Close modal (various ways)
      if (this.closeBtn) {
        this.closeBtn.addEventListener('click', () => this.closeModal());
      }
      if (this.cancelBtn) {
        this.cancelBtn.addEventListener('click', () => this.closeModal());
      }

      // Form submission
      if (this.submitBtn) {
        this.dialog
          .querySelector('form')
          .addEventListener('submit', (e) => this.handleSubmit(e));
      }

      // Keyboard: Escape closes modal (native dialog does this automatically)
      // Arrow keys: Tab navigation (native dialog handles this)
      // Backdrop click (clicking outside): native dialog closes it automatically

      // Dispatch custom event when modal opens/closes
      this.dialog.addEventListener('close', () => {
        this.dialog.dispatchEvent(new CustomEvent('modal:closed'));
      });
    }

    openModal() {
      this.dialog.showModal();
      // Prevent body scroll
      document.body.style.overflow = 'hidden';
      // Dispatch event
      this.dialog.dispatchEvent(new CustomEvent('modal:opened'));
    }

    closeModal() {
      this.dialog.close();
      // Restore body scroll
      document.body.style.overflow = '';
    }

    handleSubmit(e) {
      e.preventDefault();

      // Collect form data if form exists
      const form = this.dialog.querySelector('form');
      if (form) {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        // Dispatch custom event with form data
        this.dialog.dispatchEvent(
          new CustomEvent('modal:submit', {
            detail: data,
            bubbles: true,
          })
        );
      }

      // Close modal
      this.closeModal();
    }
  }

  // Initialize when DOM is ready
  const modal = new ModalController();

  // Listen for modal events (example usage)
  document.getElementById('lead-modal').addEventListener('modal:opened', () => {
    console.log('Modal opened - track analytics here');
  });

  document.getElementById('lead-modal').addEventListener('modal:submit', (e) => {
    console.log('Form submitted with data:', e.detail);
  });
</script>

<style>
  /* Dialog backdrop styling */
  dialog::backdrop {
    animation: fadeIn 200ms ease-out;
  }

  dialog {
    animation: slideUp 300ms ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Ensure dialog is centered and responsive */
  dialog {
    width: 90vw;
    max-width: 32rem;
    margin: auto;
  }

  /* Better backdrop color support across browsers */
  @supports (backdrop-filter: blur(1px)) {
    dialog::backdrop {
      backdrop-filter: blur(4px);
    }
  }
</style>
