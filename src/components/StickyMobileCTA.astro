---
const phoneNumber = '+19078918283';
const phoneDisplay = '907.891.8283';
---

<div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 bg-orange-700 shadow-lg md:hidden hidden">
  <a
    href={`tel:${phoneNumber}`}
    class="block px-4 py-4 flex items-center justify-center gap-3 hover:bg-orange-700 transition-colors"
  >
    <svg class="w-6 h-6 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
      />
    </svg>
    <span class="text-white font-bold text-lg uppercase tracking-wider">CALL {phoneDisplay}</span>
  </a>
</div>

<script>
  const cta = document.getElementById('sticky-cta');
  
  // Observe first section - show CTA when it scrolls out
  const firstSection = document.querySelector('main > section:first-child');
  
  if (firstSection && cta) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Hero is visible, hide CTA
          cta.classList.add('hidden');
        } else {
          // Hero scrolled out, show CTA
          cta.classList.remove('hidden');
        }
      });
    });
    
    observer.observe(firstSection);
  }
</script>

<style>
  #sticky-cta {
    animation: slideUp 300ms ease-out;
  }

  @keyframes slideUp {
    from {
      transform: translateY(100%);
    }
    to {
      transform: translateY(0);
    }
  }
</style>
