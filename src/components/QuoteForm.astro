---
interface Props {
  siteKey?: string;
}

const { siteKey } = Astro.props;
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || '';
---

<div id="quote-form-container" class="bg-stone-900 border border-orange-600/30 p-8 rounded-sm w-full shadow-2xl animate-fade-in-up">
  <div class="mb-8 border-b border-orange-600/10 pb-6 text-center">
    <h2 class="text-2xl font-display font-bold uppercase mb-2">Request Estimate</h2>
    <p class="text-stone-400 text-xs uppercase tracking-widest font-bold">The No-Surprise Guarantee</p>
  </div>

  <!-- Success Message -->
  <div id="success-message" class="hidden bg-stone-900 border border-stone-800 p-12 rounded-sm shadow-2xl text-center animate-fade-in">
    <div class="w-20 h-20 bg-green-900/20 rounded-full flex items-center justify-center mb-8 border border-green-900 text-green-500 mx-auto">
      <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 20 20">
        <path
          fill-rule="evenodd"
          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
          clip-rule="evenodd"
        />
      </svg>
    </div>
    <h2 class="text-4xl font-display font-bold uppercase mb-4">Inquiry Received!</h2>
    <p class="text-stone-400 max-w-md mb-8 leading-relaxed mx-auto">
      Thank you for trusting Deck Masters. We'll get back to you within 1 hour to discuss your project.
    </p>
    <button
      id="submit-another-btn"
      class="border border-stone-700 text-white px-8 py-3 font-bold uppercase text-xs tracking-widest hover:bg-white hover:text-stone-950 transition-all"
    >
      Submit Another Request
    </button>
  </div>

  <!-- Form -->
  <form id="quote-form" class="space-y-3 hidden">
    <!-- Error Message -->
    <div id="error-message" class="hidden bg-red-900/10 border border-red-900/50 rounded-sm p-4 flex items-start space-x-3 mb-4">
      <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path
          fill-rule="evenodd"
          d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zm-11-1a1 1 0 11-2 0 1 1 0 012 0zM8 9a1 1 0 100-2 1 1 0 000 2zm5 0a1 1 0 100-2 1 1 0 000 2z"
          clip-rule="evenodd"
        />
      </svg>
      <div>
        <p id="error-text" class="text-red-500 text-xs uppercase tracking-widest font-bold"></p>
        <button type="button" id="dismiss-error" class="text-red-600 hover:text-red-400 text-[10px] uppercase font-bold mt-2 tracking-widest">
          Dismiss
        </button>
      </div>
    </div>

    <!-- Row 1: Name + Phone -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <input
          type="text"
          name="name"
          placeholder="Full Name*"
          class="quote-input w-full px-4 py-3 bg-stone-800 border border-stone-700 text-white placeholder-stone-500 focus:outline-none focus:border-orange-600 transition-colors"
          required
        />
        <span class="error-text text-red-500 text-xs mt-1 hidden"></span>
      </div>
      <div>
        <input
          type="tel"
          name="phone"
          placeholder="Phone Number*"
          class="quote-input w-full px-4 py-3 bg-stone-800 border border-stone-700 text-white placeholder-stone-500 focus:outline-none focus:border-orange-600 transition-colors"
          required
        />
        <span class="error-text text-red-500 text-xs mt-1 hidden"></span>
      </div>
    </div>

    <!-- Row 2: Email -->
    <div>
      <input
        type="email"
        name="email"
        placeholder="Email Address*"
        class="quote-input w-full px-4 py-3 bg-stone-800 border border-stone-700 text-white placeholder-stone-500 focus:outline-none focus:border-orange-600 transition-colors"
        required
      />
      <span class="error-text text-red-500 text-xs mt-1 hidden"></span>
    </div>

    <!-- Row 3: Address -->
    <div>
      <input
        type="text"
        name="address"
        id="address-input"
        placeholder="Property Address (Start Typing)*"
        class="quote-input w-full px-4 py-3 bg-stone-800 border border-stone-700 text-white placeholder-stone-500 focus:outline-none focus:border-orange-600 transition-colors"
        required
      />
      <span class="error-text text-red-500 text-xs mt-1 hidden"></span>
    </div>

    <!-- Consent Checkboxes -->
    <div class="pt-4 space-y-2">
      <label class="flex items-start gap-3 cursor-pointer">
        <input
          type="checkbox"
          name="consent"
          class="mt-1 w-4 h-4 bg-stone-800 border border-stone-700 rounded accent-orange-600"
          required
        />
        <span class="text-stone-400 text-xs leading-relaxed uppercase">
          By checking this box I agree to Deck Masters' <a href="/terms" class="text-orange-600 hover:underline font-bold">Terms</a> & <a href="/privacy" class="text-orange-600 hover:underline font-bold">Privacy Policy</a> and consent to receive SMS messages about my project. Msg & data rates may apply. Reply STOP to opt out. *
        </span>
      </label>

      <label class="flex items-start gap-3 cursor-pointer">
        <input
          type="checkbox"
          name="marketingConsent"
          class="mt-1 w-4 h-4 bg-stone-800 border border-stone-700 rounded accent-orange-600"
        />
        <span class="text-stone-400 text-xs leading-relaxed uppercase">
          I consent to receive recurring automated marketing texts (promos, offers) from Deck Masters. Consent is not required to purchase. Msg frequency varies. Msg & data rates may apply. Reply STOP to cancel. *
        </span>
      </label>
    </div>

    <!-- Turnstile Widget -->
    <div class="pt-4">
      <div id="turnstile-container" style="display: flex; justify-content: center;"></div>
      <span id="turnstile-error" class="error-text text-red-500 text-xs mt-2 hidden block text-center"></span>
    </div>

    <!-- Submit Button -->
    <div class="pt-6">
      <button
        type="submit"
        class="w-full bg-orange-700 hover:bg-orange-800 text-white font-display font-bold uppercase py-4 transition-all tracking-widest flex items-center justify-center gap-2"
      >
        Check Availability & Get Quote
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </button>
    </div>
  </form>

  <!-- Google Reviews badge -->
  <div class="mt-6 pt-6 border-t border-stone-800 flex items-center justify-center gap-2">
    <span class="text-orange-500" aria-hidden="true">★★★★★</span>
    <span class="text-stone-400 text-xs uppercase tracking-widest font-bold">4.9, 122 Google Reviews</span>
  </div>
</div>

<script define:vars={{ siteKey, googleMapsApiKey }}>
  class QuoteFormController {
    constructor(siteKey, googleMapsApiKey) {
      this.siteKey = siteKey;
      this.googleMapsApiKey = googleMapsApiKey;
      this.turnstileToken = null;
      this.isSubmitting = false;

      this.form = document.getElementById('quote-form');
      this.container = document.getElementById('quote-form-container');
      this.successMessage = document.getElementById('success-message');
      this.errorMessage = document.getElementById('error-message');
      this.errorText = document.getElementById('error-text');

      this.init();
    }

    init() {
      // Load Turnstile
      if (this.siteKey) {
        this.loadTurnstile();
      }

      // Load Google Maps
      if (this.googleMapsApiKey) {
        this.loadGoogleMaps();
      }

      this.form.addEventListener('submit', (e) => this.handleSubmit(e));

      // Error dismiss
      document.getElementById('dismiss-error')?.addEventListener('click', () => {
        this.errorMessage.classList.add('hidden');
      });

      // Submit another button
      document.getElementById('submit-another-btn')?.addEventListener('click', () => {
        this.resetForm();
      });

      // Show form by default
      this.form.classList.remove('hidden');
    }

    loadTurnstile() {
      const script = document.createElement('script');
      script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
      script.async = true;
      script.defer = true;

      script.onload = () => {
        window.turnstile?.render('#turnstile-container', {
          sitekey: this.siteKey,
          callback: (token) => {
            this.turnstileToken = token;
          },
        });
      };

      document.head.appendChild(script);
    }

    loadGoogleMaps() {
      const script = document.createElement('script');
      script.src = `https://maps.googleapis.com/maps/api/js?key=${this.googleMapsApiKey}&libraries=places&loading=async`;
      script.async = true;
      script.defer = true;

      script.onload = () => {
        const addressInput = document.getElementById('address-input');
        if (window.google && addressInput) {
          const autocomplete = new window.google.maps.places.Autocomplete(addressInput, {
            types: ['address'],
            componentRestrictions: { country: 'us' },
            fields: ['formatted_address'],
          });

          autocomplete.addListener('place_changed', () => {
            const place = autocomplete.getPlace();
            if (place.formatted_address) {
              addressInput.value = place.formatted_address;
            }
          });
        }
      };

      document.head.appendChild(script);
    }

    validateForm() {
      const errors = [];
      const name = this.form.querySelector('input[name="name"]').value.trim();
      const email = this.form.querySelector('input[name="email"]').value.trim();
      const phone = this.form.querySelector('input[name="phone"]').value.trim();
      const consent = this.form.querySelector('input[name="consent"]').checked;

      if (!name) errors.push({ field: 'name', message: 'Name is required' });
      if (!email || !email.includes('@')) errors.push({ field: 'email', message: 'Valid email required' });
      if (!phone) errors.push({ field: 'phone', message: 'Phone number is required' });
      if (!consent) errors.push({ field: 'consent', message: 'Please accept the consent' });
      if (!this.turnstileToken) errors.push({ field: 'turnstile', message: 'Please complete the security check' });

      return errors;
    }

    showError(message) {
      this.errorText.textContent = message;
      this.errorMessage.classList.remove('hidden');
    }

    clearErrors() {
      this.errorMessage.classList.add('hidden');
      document.querySelectorAll('.error-text').forEach((el) => el.classList.add('hidden'));
    }

    async handleSubmit(e) {
      e.preventDefault();

      if (this.isSubmitting) return;

      this.clearErrors();
      const errors = this.validateForm();

      if (errors.length > 0) {
        this.showError(errors[0].message);
        return;
      }

      this.isSubmitting = true;

      const formData = new FormData(this.form);
      const data = {
        name: formData.get('name'),
        email: formData.get('email'),
        phone: formData.get('phone'),
        address: formData.get('address'),
        consent: formData.get('consent') === 'on',
        marketingConsent: formData.get('marketingConsent') === 'on',
        turnstileToken: this.turnstileToken,
      };

      try {
        const response = await fetch('/api/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          this.form.classList.add('hidden');
          this.successMessage.classList.remove('hidden');
        } else {
          this.showError('Submission failed. Please try again.');
        }
      } catch (error) {
        console.error('Form error:', error);
        this.showError('An error occurred. Please try again.');
      } finally {
        this.isSubmitting = false;
      }
    }

    resetForm() {
      this.form.reset();
      this.form.classList.remove('hidden');
      this.successMessage.classList.add('hidden');
      this.clearErrors();

      // Reset Turnstile
      if (window.turnstile) {
        window.turnstile.reset();
        this.turnstileToken = null;
      }
    }
  }

  new QuoteFormController(siteKey, googleMapsApiKey);
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 400ms ease-out;
  }

  .animate-fade-in-up {
    animation: fadeInUp 400ms ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
