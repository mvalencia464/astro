---
import { ClientRouter } from 'astro:transitions';
import '../styles/globals.css';
import favicon from '../assets/favicon.svg';
import LocalSEO from '../components/LocalSEO.astro';
// Preload critical fonts so the browser fetches them in parallel with the CSS,
// not after CSS is parsed. Oswald = headings (LCP element), Inter = body text.
import oswaldFontUrl from '../assets/fonts/Oswald-VariableFont_wght.woff2?url';
import interFontUrl from '../assets/fonts/Inter-VariableFont_opsz,wght.woff2?url';

interface RawReview {
  rating: number;
  text?: string;
  author?: string;
  date?: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  serviceName?: string;
  cityName?: string;
  region?: string;
  canonical?: string;
  reviews?: RawReview[];
}

const { 
  title, 
  description,
  ogImage,
  serviceName,
  cityName,
  region,
  canonical,
  reviews,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <LocalSEO 
      title={title} 
      description={description} 
      serviceName={serviceName} 
      cityName={cityName} 
      region={region} 
      canonical={canonical}
      reviews={reviews}
    />
    
    <!-- Preload display + body fonts before CSS is parsed → eliminates FOUT on LCP element -->
    <link rel="preload" href={oswaldFontUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={interFontUrl} as="font" type="font/woff2" crossorigin="anonymous" />

    <link rel="icon" type="image/svg+xml" href={favicon.src} />
    <ClientRouter />
    
    <!-- Google Analytics: deferred until the browser is idle so it never
         competes with LCP/FCP. Falls back to window.load on older browsers. -->
    <script is:inline>
      function _loadGA() {
        if (window.__gaLoaded) return;
        window.__gaLoaded = true;
        const s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-RD2XZW9K8V';
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){ window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', 'G-RD2XZW9K8V');
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(_loadGA, { timeout: 4000 });
      } else {
        window.addEventListener('load', _loadGA, { once: true });
      }
    </script>
    <slot name="head" />
  </head>
  <body class="bg-stone-950 text-stone-100 font-sans">
    <slot />
  </body>
</html>
