---
import { mapAssetUrl } from '../utils/assetMapper';

interface Props {
  testimonialsData: { rawReviews: Array<any> };
}

const { testimonialsData } = Astro.props;

// Filter and process reviews
const filteredReviews = (testimonialsData.rawReviews as Array<any>)
  .filter((r: any) => r.text && r.text.trim().length > 0 && r.rating >= 4)
  .map((review: any) => ({
    ...review,
    images: review.images ? review.images.map((img: string) => mapAssetUrl(img)) : [],
    avatarUrl: review.avatarUrl ? (mapAssetUrl(review.avatarUrl) as string || review.avatarUrl) : undefined,
  }))
  .sort((a, b) => {
    const aIsVideo = a.videoUrl ? 1 : 0;
    const bIsVideo = b.videoUrl ? 1 : 0;
    return bIsVideo - aIsVideo;
  })
  .slice(0, 12); // Show first 12 by default
---

<div id="reviews-grid" class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 space-y-4">
  {filteredReviews.map((review, i) => (
    <div
      key={i}
      class="review-card break-inside-avoid mb-4 bg-stone-900 border border-stone-800 overflow-hidden hover:border-orange-600/30 transition-all duration-300 group"
      data-review-id={i}
    >
      {review.images && review.images.length > 0 && (
        <div class="review-image-trigger w-full aspect-video cursor-pointer bg-stone-800 flex items-center justify-center overflow-hidden">
          <img
            src={typeof review.images[0] === 'string' ? review.images[0] : review.images[0].src}
            alt={review.author}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 0a10 10 0 1110 10A10 10 0 0110 0zm3.667 10L8.5 7.833v4.334z" />
            </svg>
          </div>
        </div>
      )}

      <div class="p-4">
        {/* Stars */}
        <div class="flex gap-1 mb-3">
          {[...Array(review.rating || 5)].map((_, i) => (
            <svg key={i} class="w-4 h-4 text-orange-500 fill-orange-500" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>

        {/* Review Text */}
        <p class="text-stone-300 text-sm line-clamp-3 mb-3 leading-relaxed">
          {review.text}
        </p>

        {/* Author */}
        <div class="flex items-center gap-2 border-t border-stone-800 pt-3">
          {review.avatarUrl && (
            <img src={review.avatarUrl} alt={review.author} class="w-8 h-8 rounded-full" />
          )}
          <div class="text-xs">
            <div class="font-semibold text-white">{review.author}</div>
            <div class="text-stone-500">{review.source || 'Google'}</div>
          </div>
        </div>
      </div>

      {/* Modal for images - shows in dialog when clicked */}
      <dialog id={`modal-${i}`} class="review-modal backdrop:bg-black/50 rounded-lg max-w-2xl w-full mx-auto">
        <form method="dialog" class="relative">
          {review.images && review.images.length > 0 && (
            <div class="relative aspect-video bg-black">
              <img
                id={`modal-img-${i}`}
                src={typeof review.images[0] === 'string' ? review.images[0] : review.images[0].src}
                alt={review.author}
                class="w-full h-full object-contain"
              />
              
              {/* Navigation if multiple images */}
              {review.images.length > 1 && (
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                  {review.images.map((_, imgIdx) => (
                    <button
                      type="button"
                      class={`modal-dot w-2 h-2 rounded-full transition ${imgIdx === 0 ? 'bg-white w-6' : 'bg-white/50'}`}
                      data-idx={imgIdx}
                      data-modal-id={i}
                      aria-label={`Image ${imgIdx + 1}`}
                    />
                  ))}
                </div>
              )}
            </div>
          )}
          <button type="submit" class="absolute top-4 right-4 text-white hover:text-gray-300 bg-black/50 p-2 rounded">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </form>
      </dialog>
    </div>
  ))}
</div>

<script define:vars={{ filteredReviews: JSON.stringify(filteredReviews) }}>
  // Open modal when image is clicked
  document.querySelectorAll('.review-image-trigger').forEach((trigger, idx) => {
    trigger.addEventListener('click', () => {
      const modal = document.getElementById(`modal-${idx}`);
      modal?.showModal();
    });
  });

  // Handle image navigation in modal
  document.querySelectorAll('.modal-dot').forEach(dot => {
    dot.addEventListener('click', (e) => {
      e.preventDefault();
      const imgIdx = parseInt(dot.dataset.idx);
      const modalId = dot.dataset.modalId;
      const img = document.getElementById(`modal-img-${modalId}`);
      const reviews = filteredReviews;
      const review = reviews[parseInt(modalId)];
      
      if (img && review.images) {
        const newSrc = typeof review.images[imgIdx] === 'string' 
          ? review.images[imgIdx] 
          : review.images[imgIdx].src;
        img.src = newSrc;
        
        // Update dot states
        document.querySelectorAll(`[data-modal-id="${modalId}"]`).forEach((d, i) => {
          if (i === imgIdx) {
            d.classList.add('bg-white', 'w-6');
            d.classList.remove('bg-white/50');
          } else {
            d.classList.remove('bg-white', 'w-6');
            d.classList.add('bg-white/50');
          }
        });
      }
    });
  });
</script>

<style>
  dialog {
    width: 90vw;
    max-width: 40rem;
  }

  dialog::backdrop {
    animation: fadeIn 200ms ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
