---
// Astro 6 Pure Component - Zero React, Zero JS Hydration
// Replaces TestimonialRotator.tsx with vanilla JavaScript
import { Icon } from 'astro-icon';

const testimonials = [
  "The decks are a work of art!",
  "Professional, precise, prompt—clean and accurate.",
  "Deck Masters made it easy—beautiful deck, great people.",
  "Couldn't recommend them enough. Smooth operation."
];
---

<div class="flex items-start gap-4 mb-6 h-20">
  <!-- Quote Icon from lucide-react equivalent using astro-icon -->
  <svg
    class="w-8 h-8 text-orange-600 flex-shrink-0 opacity-50 mt-1"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M7 8a4 4 0 01.824.156l1.06-.318a1 1 0 00-.909-1.805l-1.06.318A4 4 0 017 4m0 0a4 4 0 014 4m-4-4v4m0 0h4m-4-4L3 8m12 0a4 4 0 01-.824-.156l-1.06.318a1 1 0 00.909 1.805l1.06-.318A4 4 0 0119 12m0 0a4 4 0 01-4 4m4-4v4m0 0h-4m4-4l4 4M7 20a4 4 0 01-4-4m4 4v-4m0 0h-4"
    />
  </svg>

  <p
    id="testimonial-text"
    class="text-2xl md:text-3xl text-stone-200 font-light italic leading-tight transition-opacity duration-500 opacity-100"
  >
    {testimonials[0]}
  </p>
</div>

<script>
  const testimonials = [
    "The decks are a work of art!",
    "Professional, precise, prompt—clean and accurate.",
    "Deck Masters made it easy—beautiful deck, great people.",
    "Couldn't recommend them enough. Smooth operation."
  ];

  const testimonialText = document.getElementById('testimonial-text');
  if (testimonialText) {
    let currentIndex = 0;

    setInterval(() => {
      // Fade out
      testimonialText.classList.remove('opacity-100');
      testimonialText.classList.add('opacity-0');

      // Wait for fade animation, then update text
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % testimonials.length;
        testimonialText.textContent = testimonials[currentIndex];
        
        // Fade in
        testimonialText.classList.remove('opacity-0');
        testimonialText.classList.add('opacity-100');
      }, 500);
    }, 5000);
  }
</script>

<style>
  /* CSS transitions handle the fade animation */
  #testimonial-text {
    transition-property: opacity;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 500ms;
  }
</style>
