---
import reviewsData from '../assets/reviews.json';

interface RawReview {
  date: string;
  text: string;
  author: string;
  rating: number;
  source?: string;
  avatarUrl?: string;
  images?: string[];
  videoUrl?: string;
  videoThumbnailUrl?: string;
}

const reviews = (reviewsData.rawReviews as RawReview[])
  .filter((r) => r.text?.trim() && r.rating >= 4)
  .sort((a, b) => (b.videoUrl ? 1 : 0) - (a.videoUrl ? 1 : 0));

function renderStars(rating: number) {
  return Array.from({ length: 5 }, (_, i) => i < rating);
}

// Resolves paths from reviews.json to public-served URLs.
// Handles three conventions:
//   • http(s)://…             → pass through (remote avatar CDN)
//   • /assets/testimonials/…  → swap .webp → .avif (local files copied to public/)
//   • testimonials/videos/…   → prepend /assets/ (video files already in public/)
function resolveImagePath(path: string): string {
  if (!path) return '';
  if (path.startsWith('http')) return path;
  // Local path — ensure we serve the .avif version we have in public/
  const resolved = path.startsWith('/') ? path : `/assets/${path}`;
  return resolved.replace(/\.webp$/, '.avif');
}
---

<section aria-label="Customer reviews">
  <div class="reviews-grid" role="list">
    {reviews.map((review, i) => {
      const isPortraitVideo = review.source === 'Video Testimonial';
      const stars = renderStars(review.rating);
      const hasImages = review.images && review.images.some(img => img);
      const firstImage = hasImages ? resolveImagePath(review.images![0]) : null;
      const extraImages = hasImages ? review.images!.filter(Boolean).length - 1 : 0;
      const isLCP = i === 0;
      const modalId = `rv-modal-${i}`;

      return (
        <article class={`review-card${isPortraitVideo ? ' review-card--portrait-video' : ''}`} role="listitem">

          {/* ── Portrait video card (Erica Leman) ─────────────── */}
          {isPortraitVideo && review.videoUrl && (
            <details class="video-details video-details--portrait">
              <summary class="video-summary" aria-label={`Play video review from ${review.author}`}>
                {review.videoThumbnailUrl && (
                  <div class="video-thumb-wrap--portrait">
                    <img
                      src={resolveImagePath(review.videoThumbnailUrl)}
                      alt={`Video testimonial from ${review.author}`}
                      width="270"
                      height="480"
                      loading={isLCP ? 'eager' : 'lazy'}
                      decoding={isLCP ? 'sync' : 'async'}
                      class="review-thumb"
                    />
                    <div class="portrait-overlay">
                      <span class="play-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="64" height="64">
                          <circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.55)" />
                          <path d="M9.5 7.5l7 4.5-7 4.5V7.5z" fill="white" />
                        </svg>
                      </span>
                      <span class="portrait-author-name">{review.author.replace(' (Video)', '')}</span>
                    </div>
                  </div>
                )}
                <span class="sr-only">▶ Watch video</span>
              </summary>
              <video
                controls
                preload="none"
                poster={review.videoThumbnailUrl ? resolveImagePath(review.videoThumbnailUrl) : undefined}
                class="review-video review-video--portrait"
              >
                <source src={resolveImagePath(review.videoUrl)} type="video/mp4" />
              </video>
            </details>
          )}

          {/* ── Standard review card ───────────────────────────── */}
          {!isPortraitVideo && (
            <>
              {/* Project photo (16:9 thumbnail, opens lightbox) */}
              {hasImages && firstImage && (
                <a href={`#${modalId}`} class="review-image-link" aria-label={`View photos from ${review.author}`}>
                  <div class="review-image-wrap">
                    <img
                      src={firstImage}
                      alt={`Project photo from ${review.author}`}
                      width="400"
                      height="225"
                      loading={isLCP ? 'eager' : 'lazy'}
                      decoding={isLCP ? 'sync' : 'async'}
                      class="review-thumb"
                    />
                    {extraImages > 0 && (
                      <span class="extra-count">+{extraImages}</span>
                    )}
                  </div>
                </a>
              )}

              <div class="review-body">
                <div class="stars" aria-label={`${review.rating} out of 5 stars`} role="img">
                  {stars.map((filled) => (
                    <svg
                      class={`star ${filled ? 'star--filled' : 'star--empty'}`}
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <p class="review-text">{review.text}</p>
                <footer class="review-author">
                  {review.avatarUrl && review.avatarUrl.startsWith('http') && (
                    <img
                      src={review.avatarUrl}
                      alt=""
                      width="32"
                      height="32"
                      loading="lazy"
                      decoding="async"
                      class="avatar"
                      aria-hidden="true"
                    />
                  )}
                  <div>
                    <span class="author-name">{review.author}</span>
                    <span class="author-source">{review.source ?? 'Google'}</span>
                  </div>
                </footer>
              </div>
            </>
          )}

        </article>
      );
    })}
  </div>

  {/* Lightboxes rendered outside the grid — keeps them free from overflow:hidden
      and content-visibility containment on .review-card so position:fixed works */}
  {reviews.map((review, i) => {
    if (review.source === 'Video Testimonial') return null;
    const hasImages = review.images && review.images.some(img => img);
    if (!hasImages) return null;
    const modalId = `rv-modal-${i}`;
    return (
      <div id={modalId} class="lightbox" role="dialog" aria-modal="true" aria-label={`Photos from ${review.author}`}>
        <a href="#_" class="lightbox-backdrop" aria-label="Close photo viewer" />
        <a href="#_" class="lightbox-close" aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
            <path d="M6 18L18 6M6 6l12 12" />
          </svg>
        </a>
        <div class="lightbox-content">
          {review.images!.filter(Boolean).map((img, imgIdx) => (
            <img
              src={resolveImagePath(img)}
              alt={`Photo ${imgIdx + 1} from ${review.author}`}
              class="lightbox-img"
              loading="lazy"
              decoding="async"
            />
          ))}
          <p class="lightbox-caption">{review.author} — {review.source ?? 'Google'}</p>
        </div>
      </div>
    );
  })}
</section>

<style>
  /* ── Layout ──────────────────────────────────────── */
  .reviews-grid {
    columns: 1;
    column-gap: 1rem;
  }

  @media (min-width: 640px)  { .reviews-grid { columns: 2; } }
  @media (min-width: 1024px) { .reviews-grid { columns: 3; } }
  @media (min-width: 1280px) { .reviews-grid { columns: 4; } }

  /* ── Review card ─────────────────────────────────── */
  .review-card {
    background: rgb(28 25 23); /* stone-900 */
    border: 1px solid rgb(41 37 36); /* stone-800 */
    border-radius: 0;
    overflow: hidden;
    transition: border-color 200ms ease;
    break-inside: avoid;
    margin-bottom: 1rem;
    /* Defer off-screen rendering — key for Lighthouse */
    content-visibility: auto;
  }

  .review-card:hover {
    border-color: rgba(234 88 12 / 0.3); /* orange-600/30 */
  }

  /* ── Image thumbnail ─────────────────────────────── */
  .review-image-link {
    display: block;
    text-decoration: none;
  }

  .review-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgb(41 37 36);
  }

  .review-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 300ms ease;
  }

  .review-image-link:hover .review-thumb {
    transform: scale(1.03);
  }

  .extra-count {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    background: rgba(0 0 0 / 0.7);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.125rem 0.375rem;
    border-radius: 0;
  }

  /* ── Portrait video card (Erica Leman) ───────────── */
  .review-card--portrait-video {
    position: relative;
  }

  .video-details--portrait {
    width: 100%;
    border: none;
  }

  /* Hide the thumbnail/summary once the video is playing */
  .video-details--portrait[open] > .video-summary {
    display: none;
  }

  .video-thumb-wrap--portrait {
    position: relative;
    aspect-ratio: 9 / 16;
    width: 100%;
    background: rgb(41 37 36);
    overflow: hidden;
  }

  .portrait-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .play-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 200ms ease;
  }

  .video-summary:hover .play-icon {
    transform: scale(1.1);
  }

  .portrait-author-name {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1rem 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
  }

  .review-video--portrait {
    width: 100%;
    aspect-ratio: 9 / 16;
    display: block;
    background: black;
    object-fit: contain;
  }

  /* ── Standard video card (16:9) ──────────────────── */
  .video-details {
    border-bottom: 1px solid rgb(41 37 36);
  }

  .video-summary {
    list-style: none;
    cursor: pointer;
    position: relative;
  }

  .video-summary::-webkit-details-marker { display: none; }

  .video-thumb-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    background: rgb(41 37 36);
    overflow: hidden;
  }

  /* Hide thumbnail when video is playing */
  .video-details[open] > .video-summary {
    display: none;
  }

  .review-video {
    width: 100%;
    display: block;
    background: black;
  }

  /* ── Review body ─────────────────────────────────── */
  .review-body {
    padding: 1rem;
  }

  /* ── Stars ───────────────────────────────────────── */
  .stars {
    display: flex;
    gap: 0.125rem;
    margin-bottom: 0.75rem;
  }

  .star {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .star--filled {
    fill: rgb(249 115 22); /* orange-500 */
    color: rgb(249 115 22);
  }

  .star--empty {
    fill: rgb(68 64 60); /* stone-600 */
    color: rgb(68 64 60);
  }

  /* ── Review text ─────────────────────────────────── */
  .review-text {
    color: rgb(168 162 158); /* stone-400 */
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
    white-space: pre-wrap;
  }

  /* ── Author ──────────────────────────────────────── */
  .review-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-top: 1px solid rgb(41 37 36);
    padding-top: 0.75rem;
    margin-top: auto;
  }

  .avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: rgb(68 64 60);
  }

  .author-name {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
  }

  .author-source {
    display: block;
    font-size: 0.75rem;
    color: rgb(168 162 158); /* stone-400 — passes WCAG AA (4.5:1 on stone-900) */
  }

  /* ── CSS-only lightbox (:target) ─────────────────── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    /* Top padding clears the fixed nav bar (~4rem) + breathing room */
    padding: 5rem 1rem 1rem;
  }

  .lightbox:target {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0 0 0 / 0.85);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* Close button: absolute within the full-viewport lightbox overlay,
     so it always sits at the top-right corner of the screen */
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    color: white;
    background: rgba(0 0 0 / 0.75);
    border: 1px solid rgba(255 255 255 / 0.2);
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease;
    text-decoration: none;
    flex-shrink: 0;
  }

  .lightbox-close:hover {
    background: rgba(234 88 12 / 0.9);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    width: 100%;
    max-height: calc(100svh - 6rem);
    overflow-y: auto;
    background: rgb(28 25 23);
    border-radius: 0;
    box-shadow: 0 25px 50px rgba(0 0 0 / 0.6);
  }

  .lightbox-img {
    width: 100%;
    height: auto;
    max-height: calc(100svh - 8rem);
    object-fit: contain;
    display: block;
    background: black;
  }

  .lightbox-caption {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: rgb(168 162 158);
    margin: 0;
  }

  /* ── Utility ─────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
