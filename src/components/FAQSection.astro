---
interface FAQItem {
  id: string;
  question: string;
  answer: string;
  category?: string;
}

interface Props {
  items: FAQItem[];
  title?: string;
  subtitle?: string;
  category?: string;
  class?: string;
}

const {
  items,
  title = "Frequently Asked Questions",
  subtitle,
  category,
  class: className = "",
} = Astro.props;
---

<section class={`py-20 px-6 bg-stone-950 border-t border-stone-800 ${className}`}>
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <div class="flex items-center gap-4 mb-6">
        <div class="h-[1px] w-12 bg-orange-600" />
        <span class="text-orange-500 font-bold uppercase tracking-[0.3em] text-sm">FAQ</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-display font-bold uppercase text-white mb-4">
        {title}
      </h2>
      {subtitle && <p class="text-stone-400 text-lg max-w-2xl">{subtitle}</p>}
    </div>

    <!-- FAQ Items -->
    <div class="space-y-3">
      {items.map((item) => (
        <details
          class="faq-item border border-stone-800 overflow-hidden hover:border-orange-600/50 transition-colors duration-300"
          key={item.id}
        >
          <summary class="w-full px-6 py-5 flex items-start justify-between gap-4 bg-stone-900/50 hover:bg-stone-900 transition-colors text-left cursor-pointer select-none">
            <span class="text-base md:text-lg font-semibold text-white flex-1">
              {item.question}
            </span>
            <svg
              class="w-5 h-5 text-orange-500 flex-shrink-0 mt-0.5 transition-transform duration-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"
              />
            </svg>
          </summary>

          <!-- Answer -->
          <div class="px-6 py-5 bg-stone-900 border-t border-stone-800">
            <div class="text-stone-400 leading-relaxed space-y-3">
              {item.answer.split("\n\n").map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  summary {
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  details > summary svg {
    transform: rotate(0deg);
  }

  details[open] > summary svg {
    transform: rotate(180deg);
  }
</style>
